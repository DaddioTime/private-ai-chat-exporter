{
  "manifest_version": 3,
  "name": "Private AI Chat Exporter",
  "version": "1.3.1",
  "description": "Exports ChatGPT and Gemini conversations safely and locally as Markdown (.md), with no cloud connection.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "all_frames": false,
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    },
    "default_title": "Private AI Chat Exporter"
  }
}
