{
  "manifest_version": 3,
  "name": "Private AI Chat Exporter",
  "version": "1.0",
  "description": "Exports ChatGPT and Gemini conversations safely and locally as Markdown (.md), with no cloud connection.",
  "content_scripts": [
    {
      "all_frames": false,
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Private AI Chat Exporter"
  }
}
